# ─── Application ────────────────────────────────────────────────────────────
# Public base URL (used for canonical links, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://47sunsetstudios.com

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Add your analytics provider token here, e.g. Plausible / Fathom / Umami
# NEXT_PUBLIC_ANALYTICS_ID=

# ─── Contact / Email (optional) ──────────────────────────────────────────────
# Resend API key for transactional email delivery via the /api/contact endpoint.
# Obtain a key at https://resend.com and set it in Cloudflare Pages environment variables.
# RESEND_API_KEY=

# Recipient address for inbound inquiries (defaults to hello@47sunsetstudios.com)
# CONTACT_EMAIL=hello@47sunsetstudios.com

# Sender address shown in the From header (must be a Resend-verified domain)
# FROM_EMAIL=website@47sunsetstudios.com

# ─── Cloudflare (optional) ───────────────────────────────────────────────────
# Add any Cloudflare-specific variables (e.g. KV namespace IDs) here
# CF_KV_NAMESPACE_ID=
