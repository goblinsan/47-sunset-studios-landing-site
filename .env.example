# ─── Application ────────────────────────────────────────────────────────────
# Public base URL (used for canonical links, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://47sunsetstudios.com

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Add your analytics provider token here, e.g. Plausible / Fathom / Umami
# NEXT_PUBLIC_ANALYTICS_ID=

# ─── Contact / Email (optional) ──────────────────────────────────────────────
# Server-side secret for a transactional email service (e.g. Resend, SendGrid)
# RESEND_API_KEY=

# ─── Cloudflare (optional) ───────────────────────────────────────────────────
# Add any Cloudflare-specific variables (e.g. KV namespace IDs) here
# CF_KV_NAMESPACE_ID=
